      "parameters": {
        "jsCode": "// الكود المحسن لـ Merge Conversation\nconst input = $input.all();\nlet convId = null;\n\n// محاولة جلب الـ ID من نود Create Conversation إذا كانت المحادثة جديدة\ntry {\n    const createConv = $('Create Conversation').item.json;\n    if (createConv && createConv.id) {\n        convId = createConv.id;\n    }\n} catch (e) {\n    // تجاهل الخطأ إذا لم يتم تشغيل نود Create Conversation\n}\n\n// إذا لم نجدها، نحاول البحث في الـ Input (إذا كانت المحادثة موجودة مسبقاً)\nif (!convId && input.length > 0) {\n    convId = input[0].json.conversationId || input[0].json.id;\n}\n\nconst customerId = $('Conversation Check').item.json.customerId;\n\nif (!convId || !customerId) {\n    throw new Error('لم يتم العثور على conversationId أو customerId. تأكد من توصيل مسار False Branch بـ Create Conversation.');\n}\n\nreturn [{\n    json: {\n        conversationId: convId,\n        customerId: customerId,\n        from: $('Conversation Check').item.json.from,\n        phoneNumberId: $('Conversation Check').item.json.phoneNumberId,\n        text: $('Conversation Check').item.json.text\n    }\n}];"
      },
