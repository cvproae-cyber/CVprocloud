    {
      "parameters": {
        "jsCode": "const query = $input.first().json.query || {};\nconst expectedToken = \"cvpro_verify_2024_random\";\nconst receivedToken = query['hub.verify_token'] || query['hub_verify_token'];\nconst mode = query['hub.mode'] || query['hub_mode'];\nconst challenge = query['hub.challenge'] || query['hub_challenge'];\nif (mode === 'subscribe' && receivedToken === expectedToken) {\n  const challengeNum = parseInt(challenge, 10);\n  return [{ json: { verified: true, challenge: challengeNum } }];\n} else {\n  return [{ json: { verified: false, challenge: null } }];\n}"
      },
