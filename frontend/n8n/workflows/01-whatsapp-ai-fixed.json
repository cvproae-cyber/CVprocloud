        "jsCode": "const customers = $input.first().json;\nlet exists = false;\nlet customerId = null;\n\n// Check if customers is an array with at least one item\nif (Array.isArray(customers) && customers.length > 0) {\n  exists = true;\n  customerId = customers[0].id;\n}\n// Check if customers is a single object with an id\nelse if (customers && typeof customers === 'object' && customers.id) {\n  exists = true;\n  customerId = customers.id;\n}\n\nconst fromData = $('Build Customer URL').item.json;\nreturn [{\n  json: {\n    exists,\n    customerId,\n    from: fromData.from,\n    phoneNumberId: fromData.phoneNumberId,\n    text: fromData.text,\n    profileName: fromData.profileName\n  }\n}];"
